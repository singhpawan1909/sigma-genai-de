{
  "expectation_suite_name": "sigma_transactions_quality",
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "transaction_id"
      },
      "severity": "critical",
      "auto_fixable": false,
      "fix_action": null
    },
    {
